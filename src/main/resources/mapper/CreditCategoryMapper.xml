<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.mapper.CreditCategoryMapper">
    <select id="selectAll" resultType="org.example.entity.CreditCategory">
        SELECT * FROM credit_category
    </select>

    <select id="selectByCategoryId" parameterType="String" resultType="org.example.entity.CreditCategory">
        SELECT * FROM credit_category WHERE category_id = #{categoryId}
    </select>

    <insert id="insert" parameterType="org.example.entity.CreditCategory">
        INSERT INTO credit_category (
            category_id,
            category_name,
            credit_value,
            create_date
        ) VALUES (
                     #{categoryId},
                     #{categoryName},
                     #{creditValue},
                     #{createDate}
                 )
    </insert>

    <update id="update" parameterType="org.example.entity.CreditCategory">
        UPDATE credit_category SET
                                   category_name = #{categoryName},
                                   credit_value = #{creditValue},
                                   description = #{description}
        WHERE category_id = #{categoryId}
    </update>

    <delete id="delete" parameterType="String">
        DELETE FROM credit_category WHERE category_id = #{categoryId}
    </delete>
</mapper>